{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@alex123bob/opencode-cache-stats",
  "version": "1.0.3",
  "description": "opencode plugin — live cache hit rate widget in the TUI sidebar + per-session JSONL stats log",
  "type": "module",
  "author": "Alexander Li",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alex123bob/opencode-cache-stats.git"
  },
  "homepage": "https://github.com/alex123bob/opencode-cache-stats#readme",
  "bugs": {
    "url": "https://github.com/alex123bob/opencode-cache-stats/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js",
      "default": "./dist/tui.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "opencode",
    "plugin",
    "cache",
    "llm",
    "tui",
    "cache-hit-rate"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@opentui/core": "^0.4.3",
    "@opentui/solid": "^0.4.3",
    "solid-js": "1.9.12"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.15.0 <2"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.18",
    "@opentui/core": "^0.4.3",
    "@opentui/solid": "^0.4.3",
    "@types/node": "^24.0.0",
    "solid-js": "1.9.12",
    "tsup": "^8.5.1",
    "typescript": "^5.8.3"
  }
}
